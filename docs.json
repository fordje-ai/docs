{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Fordje Connect",
  "colors": {
    "primary": "#3B82F6",
    "light": "#2563EB",
    "dark": "#60A5FA"
  },
  "favicon": "/favicon.ico",
  "metadata": {
    "og:title": "Fordje Connect API Documentation",
    "og:description": "Programmatic access to building code and regulatory data across 30,000+ US jurisdictions.",
    "og:image": "/logo/fordje-logo.svg",
    "og:site_name": "Fordje Connect",
    "twitter:card": "summary_large_image"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "support"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/ahjs",
              "concepts/data-points",
              "concepts/collections",
              "concepts/reports",
              "concepts/categories",
              "concepts/rate-limiting",
              "concepts/errors"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/pagination"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "AHJs",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /v1/ahjs",
              "GET /v1/ahjs/{ahj_id}"
            ]
          },
          {
            "group": "Data Points",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /v1/data-points",
              "GET /v1/data-points/types"
            ]
          },
          {
            "group": "Reference Data",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /v1/categories",
              "GET /v1/units-of-measure"
            ]
          },
          {
            "group": "Reports",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /v1/reports/matrix",
              "POST /v1/reports/export"
            ]
          },
          {
            "group": "Collections",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /v1/collections",
              "GET /v1/collections/{collection_id}",
              "GET /v1/collections/{collection_id}/data",
              "POST /v1/collections/{collection_id}/export"
            ]
          },
          {
            "group": "Utility",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /health"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Resources",
            "pages": [
              "changelog",
              "versioning",
              "faq"
            ]
          },
          {
            "group": "Legal",
            "pages": [
              {
                "title": "Terms of Service",
                "href": "https://fordje.com/terms"
              },
              {
                "title": "Privacy Policy",
                "href": "https://fordje.com/privacy"
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "icon": "code",
          "href": "/api-reference/introduction"
        },
        {
          "anchor": "Changelog",
          "icon": "clock-rotate-left",
          "href": "/changelog"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@fordje.com"
      }
    ]
  },
  "footer": {
    "links": [
      {
        "title": "Legal",
        "items": [
          {
            "label": "Terms of Service",
            "href": "https://fordje.com/terms"
          },
          {
            "label": "Privacy Policy",
            "href": "https://fordje.com/privacy"
          }
        ]
      },
      {
        "title": "Resources",
        "items": [
          {
            "label": "Changelog",
            "href": "/changelog"
          },
          {
            "label": "Support",
            "href": "mailto:support@fordje.com"
          }
        ]
      }
    ]
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "required",
      "prefill": true
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
